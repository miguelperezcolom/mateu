{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "urn:eventconductor:form-schema",
  "title": "Form",
  "description": "Schema for an EventConductor form definition JSON file.",
  "type": "object",
  "required": ["name", "fields"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier. Auto-generated on import if omitted.",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "description": "Human-readable name of the form.",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "description": "Optional free-text description of the form."
    },
    "fields": {
      "type": "array",
      "description": "Ordered list of fields that make up the form.",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/Field"
      }
    }
  },
  "$defs": {
    "Field": {
      "title": "Field",
      "type": "object",
      "required": ["id", "label", "dataType"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "description": "Field identifier, unique within this form.",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "description": "Label shown to the user.",
          "minLength": 1
        },
        "dataType": {
          "type": "string",
          "description": "Data type of the field value.",
          "enum": [
            "integer",
            "string",
            "number",
            "date",
            "time",
            "dateTime",
            "bool",
            "array",
            "file",
            "status",
            "money",
            "component",
            "menu",
            "range",
            "action",
            "actionGroup",
            "dateRange"
          ]
        },
        "stereotype": {
          "type": "string",
          "description": "Visual / input stereotype that determines how the field is rendered. Defaults to 'regular' when omitted.",
          "enum": [
            "regular",
            "radio",
            "checkbox",
            "textarea",
            "toggle",
            "combobox",
            "select",
            "email",
            "password",
            "richText",
            "listBox",
            "html",
            "markdown",
            "image",
            "icon",
            "link",
            "money",
            "grid",
            "color",
            "choice",
            "popover",
            "slider",
            "button",
            "stars"
          ],
          "default": "regular"
        },
        "required": {
          "type": "boolean",
          "description": "Whether the user must provide a value for this field before submitting the form.",
          "default": false
        },
        "description": {
          "type": "string",
          "description": "Optional hint or help text shown below the field."
        }
      }
    }
  }
}
