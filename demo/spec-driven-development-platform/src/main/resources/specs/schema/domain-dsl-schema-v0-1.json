{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/domain-dsl.schema.json",
  "title": "Domain DSL Schema",
  "description": "Schema v0.1 for a model-driven DDD domain specification.",
  "type": "object",
  "additionalProperties": false,
  "required": ["domain"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "domain": {
      "$ref": "#/$defs/domain"
    },
    "imports": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "valueObjects": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/valueObject"
      }
    },
    "enums": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/enum"
      }
    },
    "entities": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/entity"
      }
    },
    "aggregates": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/aggregate"
      }
    },
    "events": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/event"
      }
    },
    "repositories": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/repository"
      }
    },
    "domainServices": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/domainService"
      }
    },
    "tests": {
      "$ref": "#/$defs/tests"
    },
    "generation": {
      "$ref": "#/$defs/generation"
    }
  },
  "$defs": {
    "domain": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "package"],
      "properties": {
        "name": {
          "$ref": "#/$defs/kebabIdentifier"
        },
        "package": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9]*(\\.[a-z][a-z0-9]*)*$"
        },
        "version": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "boundedContext": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name"],
          "properties": {
            "name": {
              "$ref": "#/$defs/typeIdentifier"
            },
            "description": {
              "type": "string"
            }
          }
        },
        "language": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "ubiquitous": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "valueObject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": {
          "oneOf": [
            { "$ref": "#/$defs/scalarType" },
            { "const": "object" }
          ]
        },
        "description": {
          "type": "string"
        },
        "immutable": {
          "type": "boolean",
          "default": true
        },
        "generation": {
          "enum": ["auto", "manual", "none"]
        },
        "fields": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/field"
          }
        },
        "constraints": {
          "$ref": "#/$defs/constraints"
        },
        "invariants": {
          "$ref": "#/$defs/invariants"
        }
      }
    },
    "enum": {
      "type": "object",
      "additionalProperties": false,
      "required": ["values"],
      "properties": {
        "description": {
          "type": "string"
        },
        "values": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^[A-Z][A-Z0-9_]*$"
          },
          "uniqueItems": true
        }
      }
    },
    "entity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["belongsTo", "identity", "fields"],
      "properties": {
        "belongsTo": {
          "$ref": "#/$defs/typeIdentifier"
        },
        "description": {
          "type": "string"
        },
        "identity": {
          "$ref": "#/$defs/namedType"
        },
        "fields": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/field"
          }
        },
        "invariants": {
          "$ref": "#/$defs/invariants"
        }
      }
    },
    "aggregate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "fields"],
      "properties": {
        "root": {
          "type": "boolean",
          "default": true
        },
        "description": {
          "type": "string"
        },
        "id": {
          "$ref": "#/$defs/namedType"
        },
        "fields": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/field"
          }
        },
        "invariants": {
          "$ref": "#/$defs/invariants"
        },
        "commands": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/command"
          }
        },
        "stateMachine": {
          "$ref": "#/$defs/stateMachine"
        },
        "hooks": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/hook"
          }
        }
      }
    },
    "field": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": {
          "$ref": "#/$defs/typeExpression"
        },
        "itemType": {
          "$ref": "#/$defs/typeExpression"
        },
        "description": {
          "type": "string"
        },
        "nullable": {
          "type": "boolean",
          "default": false
        },
        "default": {},
        "generation": {
          "enum": ["auto", "now", "uuid", "manual", "none"]
        },
        "constraints": {
          "$ref": "#/$defs/constraints"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "type": { "const": "list" } },
            "required": ["type"]
          },
          "then": {
            "required": ["itemType"]
          }
        }
      ]
    },
    "constraints": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "required": { "type": "boolean" },
        "min": { "type": "number" },
        "max": { "type": "number" },
        "minLength": { "type": "integer", "minimum": 0 },
        "maxLength": { "type": "integer", "minimum": 0 },
        "minSize": { "type": "integer", "minimum": 0 },
        "maxSize": { "type": "integer", "minimum": 0 },
        "format": {
          "enum": ["email", "uuid", "uri", "url", "date", "date-time"]
        },
        "pattern": { "type": "string" },
        "enum": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": ["string", "number", "boolean"]
          },
          "uniqueItems": true
        }
      }
    },
    "invariants": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "expression"],
        "properties": {
          "name": {
            "$ref": "#/$defs/camelIdentifier"
          },
          "when": {
            "type": "string"
          },
          "expression": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "command": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "factory": {
          "type": "boolean",
          "default": false
        },
        "description": {
          "type": "string"
        },
        "parameters": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/typeExpression"
          }
        },
        "preconditions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "sets": {
          "type": "object",
          "additionalProperties": {}
        },
        "emits": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/typeIdentifier"
          },
          "uniqueItems": true
        },
        "hooks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/camelIdentifier"
          },
          "uniqueItems": true
        }
      }
    },
    "stateMachine": {
      "type": "object",
      "additionalProperties": false,
      "required": ["field", "initial", "transitions"],
      "properties": {
        "field": {
          "$ref": "#/$defs/camelIdentifier"
        },
        "initial": {
          "type": "string"
        },
        "terminal": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "transitions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["from", "to", "command"],
            "properties": {
              "from": { "type": "string" },
              "to": { "type": "string" },
              "command": { "$ref": "#/$defs/camelIdentifier" }
            }
          }
        }
      }
    },
    "event": {
      "type": "object",
      "additionalProperties": false,
      "required": ["aggregate", "version", "fields"],
      "properties": {
        "aggregate": {
          "$ref": "#/$defs/typeIdentifier"
        },
        "version": {
          "type": "integer",
          "minimum": 1
        },
        "description": {
          "type": "string"
        },
        "fields": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/typeExpression"
          }
        }
      }
    },
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": ["aggregate"],
      "properties": {
        "aggregate": {
          "$ref": "#/$defs/typeIdentifier"
        },
        "methods": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "by": {
                "$ref": "#/$defs/camelIdentifier"
              },
              "parameter": {
                "$ref": "#/$defs/typeExpression"
              },
              "returns": {
                "$ref": "#/$defs/typeExpression"
              },
              "required": {
                "type": "boolean"
              }
            }
          }
        }
      }
    },
    "domainService": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "description": {
          "type": "string"
        },
        "inputs": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/typeExpression"
          }
        },
        "output": {
          "$ref": "#/$defs/typeExpression"
        },
        "implementation": {
          "enum": ["generated", "custom"]
        }
      }
    },
    "hook": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "method"],
      "properties": {
        "type": {
          "enum": ["custom"]
        },
        "method": {
          "$ref": "#/$defs/camelIdentifier"
        }
      }
    },
    "tests": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "generate": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "domain": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "valueObjects": { "type": "boolean" },
                "invariants": { "type": "boolean" },
                "stateMachine": { "type": "boolean" },
                "commands": { "type": "boolean" },
                "events": { "type": "boolean" }
              }
            },
            "repositories": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "contractTests": { "type": "boolean" }
              }
            },
            "serialization": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "events": { "type": "boolean" }
              }
            }
          }
        },
        "fixtures": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "generation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "overwrite": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "generated": { "type": "boolean" },
            "custom": { "type": "boolean" }
          }
        },
        "failOnManualChangesInGeneratedCode": {
          "type": "boolean"
        },
        "traceability": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "includeSpecReferenceInGeneratedCode": { "type": "boolean" }
          }
        }
      }
    },
    "namedType": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "type"],
      "properties": {
        "name": {
          "$ref": "#/$defs/camelIdentifier"
        },
        "type": {
          "$ref": "#/$defs/typeExpression"
        }
      }
    },
    "typeExpression": {
      "type": "string",
      "pattern": "^[A-Za-z][A-Za-z0-9_]*(<([A-Za-z][A-Za-z0-9_]*)(,\\s*[A-Za-z][A-Za-z0-9_]*)*>)?$|^(string|integer|long|decimal|boolean|date|instant|uuid|list)$"
    },
    "scalarType": {
      "enum": ["string", "integer", "long", "decimal", "boolean", "date", "instant", "uuid"]
    },
    "typeIdentifier": {
      "type": "string",
      "pattern": "^[A-Z][A-Za-z0-9_]*$"
    },
    "camelIdentifier": {
      "type": "string",
      "pattern": "^[a-z][A-Za-z0-9_]*$"
    },
    "kebabIdentifier": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$"
    }
  }
}
